# CampusPe WhatsApp Resume Builder Integration Environment Variables

# ===================================
# WABB (WhatsApp Business Bot) Integration
# ===================================

# WABB Webhook URLs - Get these from your WABB.in dashboard
WABB_WEBHOOK_URL_RESUME=https://wabb.in/api/webhook/your-resume-flow-id
WABB_WEBHOOK_URL_GENERAL=https://wabb.in/api/webhook/your-general-flow-id
WABB_WEBHOOK_URL_OTP=https://wabb.in/api/webhook/your-otp-flow-id

# WABB Authentication
WABB_WEBHOOK_TOKEN=your-wabb-webhook-token
WABB_API_KEY=your-wabb-api-key

# ===================================
# AI Services Configuration
# ===================================

# Claude AI (Primary)
CLAUDE_API_KEY=sk-ant-api03-your-claude-api-key

# OpenAI (Fallback)
OPENAI_API_KEY=sk-your-openai-api-key

# ===================================
# WhatsApp Business API
# ===================================

# WhatsApp Business Account Details
WHATSAPP_BUSINESS_ID=your-whatsapp-business-account-id
WHATSAPP_PHONE_NUMBER=+1234567890
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-whatsapp-webhook-verify-token

# ===================================
# Resume Generation & Storage
# ===================================

# Resume Storage Configuration
RESUME_STORAGE_TYPE=cloud
RESUME_BASE_URL=https://your-domain.com
PDF_GENERATION_TIMEOUT=60000

# File Upload Configuration
AZURE_STORAGE_ACCOUNT_NAME=your-azure-storage-account
AZURE_STORAGE_ACCOUNT_KEY=your-azure-storage-key
AZURE_STORAGE_CONTAINER_NAME=resumes

# ===================================
# Database Configuration
# ===================================

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/campuspe
# or for cloud:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/campuspe

# ===================================
# Application Configuration
# ===================================

# Server Configuration
PORT=3001
NODE_ENV=production
API_BASE_URL=https://api.campuspe.com

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=7d

# ===================================
# Monitoring & Analytics
# ===================================

# Logging Configuration
LOG_LEVEL=info
ENABLE_WHATSAPP_DEBUG=false

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
MIXPANEL_TOKEN=your-mixpanel-token

# ===================================
# Rate Limiting & Security
# ===================================

# API Rate Limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=https://campuspe.com,https://www.campuspe.com
CORS_CREDENTIALS=true

# ===================================
# Feature Flags
# ===================================

# Enable/Disable Features
ENABLE_WHATSAPP_INTEGRATION=true
ENABLE_AI_RESUME_BUILDER=true
ENABLE_CONVERSATION_FLOW=true
ENABLE_RESUME_SHARING=true

# ===================================
# Email Configuration (for notifications)
# ===================================

# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@campuspe.com

# ===================================
# WABB Flow Configuration
# ===================================

# Flow Settings
CONVERSATION_TIMEOUT_MINUTES=60
MAX_RETRY_ATTEMPTS=3
CLEANUP_INTERVAL_HOURS=1

# Message Templates
WELCOME_MESSAGE_TEMPLATE=default
ERROR_MESSAGE_TEMPLATE=default
SUCCESS_MESSAGE_TEMPLATE=default

# ===================================
# Development/Testing Configuration
# ===================================

# Development Mode Settings (only for NODE_ENV=development)
DEV_PHONE_NUMBER=+1234567890
DEV_EMAIL=test@campuspe.com
DEV_WEBHOOK_URL=https://ngrok-url.ngrok.io/api/wabb/webhook

# Testing Configuration
TEST_MODE=false
MOCK_AI_RESPONSES=false
SKIP_WHATSAPP_DELIVERY=false

# ===================================
# Backup & Recovery
# ===================================

# Backup Configuration
BACKUP_CONVERSATIONS=true
BACKUP_RESUMES=true
BACKUP_INTERVAL_HOURS=24

# Cloud Storage Backup
BACKUP_STORAGE_ACCOUNT=your-backup-storage
BACKUP_CONTAINER=backups

# ===================================
# Performance Optimization
# ===================================

# Caching Configuration
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600

# Queue Configuration
QUEUE_CONCURRENCY=5
QUEUE_DELAY_MS=1000

# ===================================
# SAMPLE VALUES FOR TESTING
# ===================================

# Use these for initial testing (replace with real values)
# WABB_WEBHOOK_URL_RESUME=https://wabb.in/api/webhook/sample-resume-flow
# WABB_WEBHOOK_TOKEN=sample-token-12345
# CLAUDE_API_KEY=sk-ant-api03-sample-key
# WHATSAPP_PHONE_NUMBER=+1234567890

# ===================================
# IMPORTANT NOTES
# ===================================

# 1. Never commit real API keys to version control
# 2. Use different webhook URLs for different environments
# 3. Test with small phone number groups first
# 4. Monitor webhook delivery rates
# 5. Set up proper logging and error tracking
# 6. Configure rate limiting to prevent abuse
# 7. Implement proper error handling for failed deliveries
# 8. Set up monitoring for conversation abandonment
# 9. Configure backup and recovery procedures
# 10. Test failover scenarios

# ===================================
# PRODUCTION CHECKLIST
# ===================================

# Before going live, ensure:
# ☐ All webhook URLs are configured and tested
# ☐ WABB flows are activated and working
# ☐ WhatsApp Business account is verified
# ☐ AI API keys are valid and have sufficient credits
# ☐ Database connections are stable
# ☐ File storage is configured and accessible
# ☐ Rate limiting is properly configured
# ☐ Error tracking and monitoring is set up
# ☐ Backup procedures are in place
# ☐ Security measures are implemented

# ===================================
# SUPPORT & TROUBLESHOOTING
# ===================================

# For support:
# - WABB.in Support: support@wabb.in
# - Claude AI Support: support@anthropic.com
# - CampusPe Support: tech@campuspe.com

# Common Issues:
# - Webhook not receiving messages: Check WABB flow configuration
# - Resume generation failing: Verify AI API keys and rate limits
# - WhatsApp delivery failing: Check webhook URLs and message format
# - Performance issues: Consider Redis caching and queue optimization
