{
  "name": "campuspe-platform",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@9.6.7",
  "scripts": {
    "dev:api": "cd apps/api && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\" --kill-others-on-fail",
    "dev:fast": "concurrently \"npm run dev:api\" \"npm run dev:web\" --kill-others-on-fail --prefix-colors blue,green",
    "build:api": "cd apps/api && npm install && npm run build",
    "build:web": "cd apps/web && npm install && npm run build",
    "prebuild": "cd apps/api && npm install",
    "build": "tsc",
    "postbuild": "echo 'API build completed successfully'",
    "start:api": "cd apps/api && npm start",
    "start:web": "cd apps/web && npm start",
    "start": "node apps/api/dist/app.js",
    "test:db": "node scripts/test-mongodb-connection.js",
    "setup": "npm install && cd apps/api && npm install && cd ../web && npm install",
    "clean": "rm -rf apps/*/node_modules apps/*/.next apps/*/dist",
    "fresh-install": "npm run clean && npm run setup"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "colors": "^1.4.0",
    "form-data": "^4.0.4",
    "nodemailer": "^7.0.5",
    "pdfkit": "^0.17.1",
    "puppeteer": "^24.15.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.0.15",
    "@types/nodemailer": "^6.4.17",
    "concurrently": "^9.2.0",
    "eslint": "^8.57.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.2"
  }
}
