<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <webSocket enabled="false" />
    
    <!-- Force a specific startup file -->
    <handlers>
      <clear />
      <add name="iisnode" path="simple-server.js" verb="*" modules="iisnode" />
    </handlers>
    
    <rewrite>
      <rules>
        <clear />
        <!-- Force all requests to go to simple-server.js -->
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^simple-server.js\/debug[\/]?" />
        </rule>
        <rule name="ForceSimpleServer" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="True"/>
          </conditions>
          <action type="Rewrite" url="simple-server.js"/>
        </rule>
      </rules>
    </rewrite>
    
    <!-- Clear all caching -->
    <staticContent>
      <clientCache cacheControlMode="DisableCache" />
    </staticContent>
    
    <security>
      <requestFiltering>
        <hiddenSegments>
          <remove segment="bin"/>
        </hiddenSegments>
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>
    
    <httpErrors existingResponse="PassThrough" />
    
    <!-- Force restart with new settings -->
    <iisnode 
      watchedFiles="web.config;*.js"
      node_env="%node_env%"
      nodeProcessCountPerApplication="1"
      maxConcurrentRequestsPerProcess="1024"
      loggingEnabled="true"
      logDirectoryNameSuffix="logs"
      debuggingEnabled="false"
      devErrorsEnabled="true"
      maxLogFileSizeInKB="128"
      appendToExistingLog="false"
      logFileFlushInterval="5000"
      configOverrides="iisnode.yml" />
  </system.webServer>
</configuration>
